@prefix seko-issues: <https://github.com/NatLibFi/SEKO/issues/> .


### Vocabulary metadata - https://dgarijo.github.io/Widoco/doc/bestPractices/index-en.html

seko-meta: a owl:Ontology ;
  dct:description """
  SEKO3 - SEKO ontologian monikielisen version tietomalli.
  """@fi ;
  dct:license <http://creativecommons.org/publicdomain/zero/1.0/> ;
  dct:description """
  SEKO3 Data model for a multilingual SEKO ontology for medium of performance.
   """@en,
  dct:title "Tietomalli monikielisen SEKO ontologian pohjaksi."@fi ;
  rdfs:comment "Muodostettu AI-assistentin tuella (Gemini, ChatGPT)."@fi ;
  dct:language <http://id.loc.gov/vocabulary/iso639-1/fi>,
             <http://id.loc.gov/vocabulary/iso639-1/sv>,
             <http://id.loc.gov/vocabulary/iso639-1/en> ;
  dc:creator <http://www.wikidata.org/entity/Q95592946> ;       # Jarmo Saarikko
  dct:contributor  <http://www.wikidata.org/entity/Q95592946>,  # Jarmo Saarikko
                   <https://www.wikidata.org/wiki/Q109126095> ; # MUUSA
  dct:mediator <http://www.wikidata.org/entity/Q420747> ;
  dct:created "2026-06-23"^^xsd:date  ;
# dct:issued "2026-06-23"^^xsd:date ;
  dct:modified "2026-07-09"^^xsd:date ; 
  owl:versionInfo "0.03" ;
.
  
### Vocabulary Classes and properties (for Finnish labels)

### LUOKKAMÄÄRITTELYT (CLASSES)

skos:ConceptScheme a owl:Class ;
    rdfs:label "Sanasto / Käsitejärjestelmä"@fi , "Concept Scheme"@en .

skos:Concept a owl:Class ;
    rdfs:label "Soitinalan käsite"@fi , "Musical Instrument Concept"@en .

skos:Collection a owl:Class ;
    rdfs:label "Kokoelma tai ryhmittely"@fi , "Collection"@en .

foaf:Agent a rdfs:Class ;
   rdfs:comment "Kuka tahansa osallistuva toimija."@fi, "Any type of agent contributing or participating."@en .


### OMINAISUUDET 

# Ontologia käyttää skos-perusominaisuuksia kuten: 
# skos:prefLabel, skos:altLabel, skos:hiddenLabel
# skos:definition, skos:scopeNote, skos:editorialNote, skos:changeNote, skos:notation 
# skos:narrower, skos:member , skos:broader , skos:narrower, skos:inScheme 
# dct:created, dct:modified 

### ARVOTYYPPIOMINAISUUDET (OWL DATATYPE PROPERTIES - Literaalit ja merkkijonot)

skos:definition 
    rdfs:comment "Käytetään organologisen ja fyysisen rakenteen kuvaamiseen."@fi .

skos:scopeNote 
    rdfs:comment "Käytetään kulttuurisen ja musiikillisen käyttöympäristön kuvaamiseen."@fi .

skos:changeNote 
    rdfs:comment "Muutoshuomatukseen liitetään joko linkki muutoksen käsittelyn issueeseen tai päiväys ja selostus muutoksesta." .

skos:notation 
    rdfs:comment "Hornbostel-Sachs-soitinluokituksen numeerinen koodi (esim. '111.24')."@fi .
skos:note
    rdfs:comment "Lyhyt kuvaus soittimesta"@fi .

dct:identifier 
    rdfs:label "Tunniste"@fi , "Identifier"@en ;
    rdfs:comment "Käsitteen uniikki paikallinen tai globaali tunnistenumero/merkkijono."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Literal .

owl:deprecated 
    rdfs:label "Poistettu käytöstä"@fi , "Is Deprecated"@en ;
    rdfs:domain skos:Concept, skos:ConceptGroup ; 
    rdfs:range xsd:boolean .

### OLIOMINAISUUDET (OWL OBJECT PROPERTIES - URI-viittaukset ja resurssit)

dct:subject 
    rdfs:label "Aihe tai luokitus"@fi , "Subject or classification"@en ;
    rdfs:comment "Käytä aiheen (esim. YSO) tai luokan (esim. Hornbostel-Sachs) URI -tunnistetta"@fi, "Use an URI for a subject or classification"@en ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .

dct:spatial 
    rdfs:label "Maantieteellinen koodi"@fi , "Spatial Coverage"@en ;
    rdfs:comment "Soittimen maantieteellinen alkuperämaa YSO-paikat viittauksena."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .

dct:creator 
    rdfs:label "Instrumentin kehittäjä"@fi, "Developer of the instrument"@en ;
    rdfs:comment "Soittimen luoja"@fi , "Creator of the instrument"@en ;
    rdfs:domain skos:Concept ; 
    rdfs:range foaf:Agent .

adms:status 
    rdfs:label "Elinkaaren tila"@fi , "Status"@en ;
    rdfs:comment "Käsitteen hallinnollinen tila. Arvoalueena käytetään MARC21-mstatus-koodistoa tai muuta vastaavaa kontrolloitua listaa."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .  #  example http://metadataregistry.org/uri/RegStatus/

### OPTONAL  see seko:statusNote - an annotation property better suited for this purpose.

dct:isReplacedBy 
    rdfs:label "Korvaava käsite"@fi , "Is Replaced By"@en ;
    rdfs:comment "Osoittaa käsitteen, joka korvaa käytöstä poistetun tai virheellisen käsitteen."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range skos:Concept .

skos:related 
    rdfs:label "Lähikäsite"@fi , "Related Concept"@en ;
    rdfs:comment "Yhdistää käsitteet, jotka liittyvät toisiinsa assosiatiivisesti tai jotka luetteloinnissa sekoitetaan herkästi keskenään."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range skos:Concept .

skos:exactMatch 
    rdfs:label "Tarkka vastaavuus"@fi , "Exact Match"@en ;
    rdfs:comment "Tarkka vastaavuus muihin sanastoihin (kuten YSO, Wikidata, MIMO, LCMPT)."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .

skos:closeMatch a owl:ObjectProperty ;
    rdfs:label "Läheinen vastaavuus"@fi , "Close Match"@en ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .

skos:broadMatch a owl:ObjectProperty ;
    rdfs:label "Laajempi vastaavuus"@fi , "Broad Match"@en ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .

rdfs:seeAlso a owl:ObjectProperty ;
    rdfs:label "Katso myös"@fi , "See Also"@en ;
    rdfs:comment "Viittaukset ulkoiseen dokumentaatioon tai tietokantoihin URI-muodossa."@fi ;
    rdfs:domain skos:Concept ; 
    rdfs:range rdfs:Resource .

###  status property

seko:statusNote a owl:AnnotationProperty ;
    rdfs:subPropertyOf skos:note ;
    rdfs:label "Tietueen tila"@fi, "Seko concept status"@en ;
    rdfs:range rdfs:Literal ;
    ddfs:domain rdfs:Resource ;
    skos:definition "A note intended strictly for Seko internal use."@en ;
    skos:scopeNote "Select value from: submitted, accepted, valid, deprecated, superceded, retired" ;
    skos:editorialNote "Only one value per record at any time.",
                       "Change and its reason should be registered in a skos:editorialNote" ;
    dct:source  https://dd.eionet.europa.eu/vocabulary/datadictionary/status/view  .

###  Experimental - classes and properties for knowledge graph development 
###
###  e.g. Music Ontology (2007) https://motools.sourceforge.net/doc/musicontology.html
###  e.g. https://performedmusicontology.org/ -- Performed Music Ontology 2.0 
###  and https://performedmusicontology.org/vocabularies/ensemble_size/PMOEnsembleSize.html
###  - An extension of the BIBFRAME ontology for describing performed music, both for mainstream and archival performed music collections. Part of these have been included into Bibframe 3.0
###  e.g. from Bibframe  bf:Ensemble, bf:MusicEnsemble, bf:MusicVoice, bf:MusicInstrument

